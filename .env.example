# Echo Backend
ECHO_BASE_URL=http://your-vm:8000
ECHO_BEARER_TOKEN=your-secret-token
ECHO_DEVICE_ID=pi-zero-1

# OpenAI (STT)
OPENAI_API_KEY=sk-...

# Display (optional)
# No Whisplay hardware or GPIO errors? Use web simulator:
#   WHISPLAY_DEVICE_ENABLED=false
#   WHISPLAY_WEB_ENABLED=true
# Then open http://<pi-ip>:17880 from another device
WHISPLAY_DEVICE_ENABLED=true
WHISPLAY_WEB_ENABLED=false
WHISPLAY_WEB_PORT=17880

# Audio
SOUND_CARD_INDEX=1
